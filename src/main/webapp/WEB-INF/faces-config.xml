<?xml version="1.0" encoding="utf-8"?>
<faces-config version="2.0" xmlns="http://java.sun.com/xml/ns/javaee"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-facesconfig_2_0.xsd">
    <application>
        <el-resolver>org.springframework.web.jsf.el.SpringBeanFacesELResolver</el-resolver>

        <locale-config>
            <default-locale>tr</default-locale>
            <supported-locale>en</supported-locale>
        </locale-config>

        <message-bundle>
            messages
        </message-bundle>
        <resource-bundle>
            <base-name>tr.ozanbey.agricalc.webapp.webapp.util.CustomResourceBundle</base-name>
            <var>msg</var>
        </resource-bundle>
    </application>

    <factory>
        <exception-handler-factory>tr.ozanbey.agricalc.webapp.webapp.util.CustomExceptionHandlerFactory</exception-handler-factory>
    </factory>

    <converter>
        <converter-for-class>java.lang.Enum</converter-for-class>
        <converter-class>jakarta.faces.convert.EnumConverter</converter-class>
    </converter>
    
    <name>primefaces_freya</name>
    <component>
        <component-type>org.primefaces.component.FreyaMenu</component-type>
        <component-class>org.primefaces.freya.component.FreyaMenu</component-class>
    </component>
    
    <render-kit>
        <renderer>
            <component-family>org.primefaces.component</component-family>
            <renderer-type>org.primefaces.component.FreyaMenuRenderer</renderer-type>
            <renderer-class>org.primefaces.freya.component.FreyaMenuRenderer</renderer-class>
        </renderer>
    </render-kit>
    
</faces-config>